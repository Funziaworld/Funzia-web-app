# Paystack Configuration
# Get these from your Paystack dashboard: https://dashboard.paystack.com/#/settings/developer

# Paystack Secret Key (for server-side operations)
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here

# Paystack Public Key (for client-side operations)
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Paystack Webhook Secret (for webhook verification)
# Set this in your Paystack dashboard under Settings > Webhooks
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret_here

# Public Paystack Key (exposed to client)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here

# Application URL (for callback URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase Configuration
# Get these from your Supabase dashboard: https://app.supabase.com
# If not provided, the app will fall back to JSON file storage

# Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Service Role Key (for server-side operations)
# IMPORTANT: Keep this secret! Never expose this in client-side code.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
